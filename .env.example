# Скопируй этот файл в .env и заполни.
# BOT_TOKEN получи у @BotFather в Telegram за 2 минуты (бесплатно): /newbot
BOT_TOKEN=

# Telegram ID администратора(ов) — узнать свой ID можно у бота @userinfobot.
# Несколько админов — через запятую: 111111111,222222222
ADMIN_IDS=

# Данные бизнеса (показываются клиенту)
BUSINESS_NAME=Салон красоты «Пример»
BUSINESS_ADDRESS=г. Минск, ул. Примерная, 1
BUSINESS_PHONE=+375 (29) 000-00-00

# Часовой пояс для напоминаний
TZ=Europe/Minsk

# HTTPS-ссылка на Mini App (после деплоя webapp/ на GitHub Pages / Cloudflare Pages).
# Если пусто — бот работает в чат-режиме без кнопки приложения.
WEBAPP_URL=

